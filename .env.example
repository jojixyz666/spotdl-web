# ──────────────────────────────────────────────
# SpotDL Web - Environment Variables
# ──────────────────────────────────────────────

# Flask
SECRET_KEY=change_me_in_production

# MySQL Database
DB_HOST=localhost
DB_USER=spotdl_user
DB_PASSWORD=your_mysql_password_here
DB_NAME=spotdl_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Admin (auto-created on first run)
ADMIN_USER=admin
ADMIN_PASS=change_me_in_production

# HTTPS (set to 1 if behind HTTPS proxy)
HTTPS_ENABLED=0

# Spotify (optional - enables unlimited tracks via Web API, requires Premium)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
